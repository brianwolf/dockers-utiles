# -----------------------------------------------------------------------------
# Dart / Flutter
# -----------------------------------------------------------------------------
.dart_tool/
.packages
.pub-cache/
.pub/
build/
# If you are using flutter_web
build_release/

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
.dockerignore
# Ignore local environment files (IMPORTANT: keep your secrets out of Git!)
.env
.env.local
.env.*.local
# Ignore large docker-related logs or temporary build files
docker-compose.override.yml

# -----------------------------------------------------------------------------
# IDEs (Visual Studio Code, IntelliJ, Android Studio)
# -----------------------------------------------------------------------------
# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# IntelliJ / Android Studio
.idea/
*.iml
*.iws
*.ipr
out/

# -----------------------------------------------------------------------------
# OS Specific (Mac, Windows, Linux)
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# -----------------------------------------------------------------------------
# Logs and Misc
# -----------------------------------------------------------------------------
*.log
pubspec.lock # Optional: keep if it's an app, ignore if it's a library